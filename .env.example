# Autodesk Platform Services (APS) Credentials
# Get these from https://aps.autodesk.com/myapps
# Required scopes: data:read, data:write, bucket:read, viewables:read
APS_CLIENT_ID=your_client_id_here
APS_CLIENT_SECRET=your_client_secret_here

# Aliases for forge-server-utils compatibility (use same values as above)
FORGE_CLIENT_ID=your_client_id_here
FORGE_CLIENT_SECRET=your_client_secret_here

# Optional: bucket key for reference
APS_BUCKET_KEY=your_bucket_key

# Server configuration
PORT=3000

# Download directory for SVF/SVF2 derivatives
DOWNLOAD_DIR=./data/downloads

# Converted models directory (GLB output from APS/SVF)
CONVERTED_DIR=./data/converted

# IFC files directory (uploaded IFC files)
IFC_DIR=./data/ifc

# Converted IFC models directory (GLB output from IFC)
CONVERTED_IFC_DIR=./data/converted-ifc

# Point clouds directories
POINTCLOUD_DIR=./data/pointclouds
POINTCLOUD_RAW_DIR=./data/pointclouds_raw
POINTCLOUD_CACHE_DIR=./data/pointclouds_cache

# PotreeConverter path (for LAS/LAZ/E57 conversion)
# Download from: https://github.com/potree/PotreeConverter/releases
POTREE_CONVERTER_PATH=PotreeConverter

# Alignment data directory (BIM-to-pointcloud transforms)
ALIGNMENT_DIR=./data/alignment

# SVF translation polling configuration
# Interval between manifest polls (milliseconds)
SVF_POLL_INTERVAL_MS=5000
# Maximum time to wait for SVF translation (milliseconds)
SVF_POLL_TIMEOUT_MS=600000
